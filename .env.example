# =====================================================================
# DM_Tools — Environment configuration
# Copy this file to `.env` and fill in the values you need.
# Every key here is OPTIONAL until you actually use the tool that
# requires it. Keys are stored in the local SQLite DB encrypted with
# Fernet — set ENCRYPTION_KEY before adding any keys via the UI.
# =====================================================================

# --- Required for storing API keys in the DB (Fernet encryption) ---
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- LLM timeouts / retry policy (sane defaults) ---
LLM_TIMEOUT=120.0
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_MIN_WAIT=4.0
LLM_RETRY_MAX_WAIT=10.0

# --- Server ---
HOST=127.0.0.1
PORT=8000
DEBUG=false

# =====================================================================
# Optional integrations — leave blank to disable a feature
# =====================================================================

# Raindrop.io (sync competitors as bookmarks)
RAINDROP_TOKEN=
RAINDROP_CLIENT_ID=
RAINDROP_CLIENT_SECRET=

# Google PageSpeed Insights (Lighthouse scores in Website Analyzer).
# Public quota works without a key but is heavily rate-limited.
PAGESPEED_API_KEY=

# =====================================================================
# Reference: providers you can add API keys for via the Settings tab.
# These do NOT need to be set as env vars — the UI stores them encrypted
# in the local SQLite DB. Listed only so you know what to grab from
# each provider:
#
#   openai      → https://platform.openai.com/api-keys
#   anthropic   → https://console.anthropic.com/settings/keys
#   gemini      → https://aistudio.google.com/app/apikey
#   mistral     → https://console.mistral.ai/api-keys
#   groq        → https://console.groq.com/keys
#   perplexity  → https://www.perplexity.ai/settings/api
#   cohere      → https://dashboard.cohere.com/api-keys
#   together    → https://api.together.xyz/settings/api-keys
#   xai         → https://console.x.ai
#   deepseek    → https://platform.deepseek.com/api_keys
#   qwen        → https://dashscope.console.aliyun.com/
#   glm         → https://open.bigmodel.cn/usercenter/apikeys
#   minimax     → https://www.minimaxi.com/user-center/basic-information/interface-key
#   kimi        → https://platform.moonshot.cn/console/api-keys
#   ollama      → local, no key needed (uses base URL field instead)
# =====================================================================
